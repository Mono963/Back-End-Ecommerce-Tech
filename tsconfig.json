{
  "compilerOptions": {
    // Configuración de módulos
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],

    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true, // Para mejor debugging
    "removeComments": true,

    // Decoradores y metadatos
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    // Configuración de paths
    "baseUrl": "./",
    "paths": {
      "../*": ["src/*"],
      "@/*": ["src/*"], // Alias adicional más común
      "@modules/*": ["src/modules/*"],
      "@common/*": ["src/common/*"],
      "@config/*": ["src/config/*"]
    },

    // Optimizaciones de compilación
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo", // Mejor ubicación
    "skipLibCheck": true,

    "strict": false,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts", "**/*test.ts", "**/*.e2e-spec.ts"]
}
